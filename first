"""
Content generation engine that creates study materials from raw text.
Generates tutor notes, quizzes, flashcards, and mind map data algorithmically.
"""
import re
import random
from typing import Any
def _split_into_sections(text: str) -> list[dict[str, str]]:
    """Split text into logical sections based on headings, blank lines, or paragraphs."""
    lines = text.strip().split("\n")
    sections: list[dict[str, str]] = []
    current_title = "Overview"
    current_content: list[str] = []
    for line in lines:
        stripped = line.strip()
        # Detect headings: lines that are short, capitalized, or end with ':'
        is_heading = (
            (len(stripped) < 80 and stripped.isupper() and len(stripped) > 2) or
            (stripped.endswith(":") and len(stripped) < 100) or
            (stripped.startswith("#")) or
            (stripped.startswith("Chapter ") or stripped.startswith("Section ") or stripped.startswith("Part "))
        )
        if is_heading and current_content:
            content_text = "\n".join(current_content).strip()
            if content_text:
                sections.append({"title": current_title, "content": content_text})
            current_title = stripped.lstrip("#").strip().rstrip(":")
            current_content = []
        elif stripped:
            current_content.append(stripped)
    # Add last section
    if current_content:
        content_text = "\n".join(current_content).strip()
        if content_text:
            sections.append({"title": current_title, "content": content_text})
    # If no sections were created, make one from the whole text
    if not sections:
        sections.append({"title": "Overview", "content": text.strip()})
    return sections
def _extract_sentences(text: str) -> list[str]:
    """Extract clean sentences from text."""
    # Split on sentence-ending punctuation
    raw = re.split(r'(?<=[.!?])\s+', text)
    sentences = []
    for s in raw:
        s = s.strip()
        if len(s) > 15 and len(s) < 500:
            sentences.append(s)
    return sentences
def _extract_key_terms(text: str) -> list[str]:
    """Extract important terms/phrases from text."""
    # Find capitalized phrases (likely proper nouns / key concepts)
    terms = set()
    # Multi-word capitalized phrases
    for match in re.finditer(r'\b([A-Z][a-z]+(?:\s+[A-Z][a-z]+)+)\b', text):
        terms.add(match.group())
    # Words in quotes
    for match in re.finditer(r'"([^"]+)"', text):
        if len(match.group(1)) < 60:
            terms.add(match.group(1))
    # Bold/emphasized terms (markdown)
    for match in re.finditer(r'\*\*([^*]+)\*\*', text):
        terms.add(match.group(1))
    for match in re.finditer(r'\*([^*]+)\*', text):
        terms.add(match.group(1))
    # Words after "called", "known as", "defined as", "refers to"
    for match in re.finditer(r'(?:called|known as|defined as|refers to|termed)\s+([A-Za-z\s]+?)(?:\.|,|\s+is|\s+are|\s+was)', text, re.IGNORECASE):
        term = match.group(1).strip()
        if len(term) < 50:
            terms.add(term)
    return list(terms)[:20]
def generate_tutor_notes(text: str, title: str) -> dict[str, Any]:
    """Generate structured tutor notes explaining content with where/when/why/how."""
    sections = _split_into_sections(text)
    notes: list[dict[str, Any]] = []
    for section in sections:
        sentences = _extract_sentences(section["content"])
        key_terms = _extract_key_terms(section["content"])
        # Build explanation sections
        explanation: dict[str, str] = {}
        # What - summary of the content
        if sentences:
            explanation["what"] = sentences[0] if len(sentences) > 0 else section["content"][:200]
        # Where - look for location/context clues
        where_sentences = [s for s in sentences if any(w in s.lower() for w in
            ["where", "location", "place", "region", "country", "city", "area", "in the", "at the", "continent"])]
        if where_sentences:
            explanation["where"] = where_sentences[0]
        # When - look for time references
        when_sentences = [s for s in sentences if any(w in s.lower() for w in
            ["when", "year", "century", "date", "period", "era", "during", "after", "before", "in 1", "in 2", "age of"])]
        if when_sentences:
            explanation["when"] = when_sentences[0]
        # Why - look for causal explanations
        why_sentences = [s for s in sentences if any(w in s.lower() for w in
            ["because", "reason", "why", "cause", "result", "purpose", "in order to", "due to", "led to", "therefore"])]
        if why_sentences:
            explanation["why"] = why_sentences[0]
        # How - look for process/method descriptions
        how_sentences = [s for s in sentences if any(w in s.lower() for w in
            ["how", "method", "process", "step", "procedure", "through", "by using", "mechanism", "technique", "approach"])]
        if how_sentences:
            explanation["how"] = how_sentences[0]
        # Key points - remaining important sentences
        key_points = [s for s in sentences[:8] if s not in [
            explanation.get("what", ""),
            explanation.get("where", ""),
            explanation.get("when", ""),
            explanation.get("why", ""),
            explanation.get("how", ""),
        ]]
        notes.append({
            "title": section["title"],
            "explanation": explanation,
            "key_points": key_points[:5],
            "key_terms": key_terms[:8],
            "full_content": section["content"],
        })
    return {
        "title": title,
        "sections": notes,
        "total_sections": len(notes),
    }
def generate_quiz(text: str, title: str) -> dict[str, Any]:
    """Generate quiz questions from the text."""
    sentences = _extract_sentences(text)
    questions: list[dict[str, Any]] = []
    if not sentences:
        return {"title": title, "questions": [], "total_questions": 0}
    # Generate fill-in-the-blank questions
    for sentence in sentences:
        words = sentence.split()
        if len(words) < 5:
            continue
        # Find a meaningful word to blank out (not common words)
        common_words = {"the", "a", "an", "is", "are", "was", "were", "be", "been",
                       "being", "have", "has", "had", "do", "does", "did", "will",
                       "would", "could", "should", "may", "might", "can", "shall",
                       "to", "of", "in", "for", "on", "with", "at", "by", "from",
                       "it", "its", "this", "that", "these", "those", "and", "or",
                       "but", "not", "no", "if", "then", "than", "so", "as", "up"}
        content_words = [(i, w) for i, w in enumerate(words)
                        if w.lower().strip(".,;:!?\"'()") not in common_words
                        and len(w.strip(".,;:!?\"'()")) > 3]
        if not content_words:
            continue
        idx, answer_word = random.choice(content_words)
        clean_answer = answer_word.strip(".,;:!?\"'()")
        # Create the blank version
        blank_sentence = " ".join(
            "________" if i == idx else w for i, w in enumerate(words)
        )
        # Generate wrong answers from other content words in the text
        all_content = set()
        for s in sentences:
            for w in s.split():
                cleaned = w.strip(".,;:!?\"'()")
                if cleaned.lower() not in common_words and len(cleaned) > 3:
                    all_content.add(cleaned)
        wrong_answers = [w for w in all_content if w.lower() != clean_answer.lower()]
        random.shuffle(wrong_answers)
        wrong_answers = wrong_answers[:3]
        if len(wrong_answers) < 2:
            continue
        options = wrong_answers[:3] + [clean_answer]
        random.shuffle(options)
        questions.append({
            "type": "fill_blank",
            "question": blank_sentence,
            "options": options,
            "correct_answer": clean_answer,
            "explanation": sentence,
        })
        if len(questions) >= 15:
            break
    # Generate true/false questions
    for sentence in sentences[::2]:
        if len(questions) >= 20:
            break
        if len(sentence.split()) < 6:
            continue
        questions.append({
            "type": "true_false",
            "question": f'True or False: "{sentence}"',
            "options": ["True", "False"],
            "correct_answer": "True",
            "explanation": f"This statement is directly from the study material: {sentence}",
        })
        if len(questions) >= 20:
            break
    random.shuffle(questions)
    return {
        "title": title,
        "questions": questions[:20],
        "total_questions": len(questions[:20]),
    }
def generate_flashcards(text: str, title: str) -> dict[str, Any]:
    """Generate flashcards from the text."""
    sections = _split_into_sections(text)
    cards: list[dict[str, str]] = []
    for section in sections:
        sentences = _extract_sentences(section["content"])
        key_terms = _extract_key_terms(section["content"])
        # Create term-definition flashcards
        for term in key_terms:
            # Find the sentence containing this term
            for sentence in sentences:
                if term.lower() in sentence.lower():
                    cards.append({
                        "front": f"What is {term}?",
                        "back": sentence,
                        "category": section["title"],
                    })
                    break
        # Create question-answer flashcards from sentences
        for sentence in sentences:
            if len(sentence.split()) < 6:
                continue
            words = sentence.split()
            # Create a question from the first part
            if len(words) > 8:
                half = len(words) // 2
                front = " ".join(words[:half]) + "..."
                cards.append({
                    "front": f"Complete this: {front}",
                    "back": sentence,
                    "category": section["title"],
                })
        # Key concept cards
        if sentences:
            cards.append({
                "front": f"What are the key points about {section['title']}?",
                "back": " ".join(sentences[:3]),
                "category": section["title"],
            })
    # Remove duplicates and limit
    seen = set()
    unique_cards = []
    for card in cards:
        key = card["front"]
        if key not in seen:
            seen.add(key)
            unique_cards.append(card)
    return {
        "title": title,
        "cards": unique_cards[:30],
        "total_cards": len(unique_cards[:30]),
    }
def generate_mindmap(text: str, title: str) -> dict[str, Any]:
    """Generate mind map data from the text."""
    sections = _split_into_sections(text)
    nodes: list[dict[str, Any]] = []
    edges: list[dict[str, str]] = []
    # Root node
    root_id = "root"
    nodes.append({
        "id": root_id,
        "label": title,
        "type": "root",
    })
    for i, section in enumerate(sections):
        section_id = f"section_{i}"
        nodes.append({
            "id": section_id,
            "label": section["title"],
            "type": "section",
        })
        edges.append({
            "source": root_id,
            "target": section_id,
        })
        # Extract key concepts for this section
        key_terms = _extract_key_terms(section["content"])
        sentences = _extract_sentences(section["content"])
        # Add key term nodes
        for j, term in enumerate(key_terms[:5]):
            term_id = f"term_{i}_{j}"
            # Find context sentence
            context = ""
            for s in sentences:
                if term.lower() in s.lower():
                    context = s
                    break
            nodes.append({
                "id": term_id,
                "label": term,
                "type": "concept",
                "detail": context,
            })
            edges.append({
                "source": section_id,
                "target": term_id,
            })
        # Add key point nodes (from sentences)
        for j, sentence in enumerate(sentences[:3]):
            point_id = f"point_{i}_{j}"
            # Shorten for display
            short = sentence[:60] + "..." if len(sentence) > 60 else sentence
            nodes.append({
                "id": point_id,
                "label": short,
                "type": "detail",
                "detail": sentence,
            })
            edges.append({
                "source": section_id,
                "target": point_id,
            })
    return {
        "title": title,
        "nodes": nodes,
        "edges": edges,
        "total_nodes": len(nodes),
    }

