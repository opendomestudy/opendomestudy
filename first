    current_user: dict = Depends(get_current_user),
):
    valid_modes = {"tutor_notes", "quiz", "flashcards", "mindmap"}
    if progress.mode not in valid_modes:
        raise HTTPException(status_code=400, detail=f"Invalid mode. Must be one of: {valid_modes}")
    with get_db() as db:
        lesson = db.execute(
            "SELECT id FROM lessons WHERE id = ? AND user_id = ?",
            (lesson_id, current_user["user_id"])
        ).fetchone()
        if not lesson:
            raise HTTPException(status_code=404, detail="Lesson not found")
        db.execute("""
            INSERT INTO progress (user_id, lesson_id, mode, score, completed, data, updated_at)
            VALUES (?, ?, ?, ?, ?, ?, CURRENT_TIMESTAMP)
            ON CONFLICT(user_id, lesson_id, mode)
            DO UPDATE SET score = ?, completed = ?, data = ?, updated_at = CURRENT_TIMESTAMP
        """, (
            current_user["user_id"], lesson_id, progress.mode,
            progress.score, progress.completed, progress.data,
            progress.score, progress.completed, progress.data,
        ))
    return {"message": "Progress updated"}
@app.get("/lessons/{lesson_id}/progress")
async def get_progress(lesson_id: int, current_user: dict = Depends(get_current_user)):
    with get_db() as db:
        progress = db.execute(
            "SELECT mode, score, completed, data, updated_at FROM progress WHERE user_id = ? AND lesson_id = ?",
            (current_user["user_id"], lesson_id)
        ).fetchall()
    return {p["mode"]: {
        "score": p["score"],
        "completed": p["completed"],
        "data": p["data"],
        "updated_at": p["updated_at"],
    } for p in progress}
